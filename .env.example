# Azure Databricks workspace URL (스킴 포함)
# 예: https://adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HOST=https://<workspace-host>

# 사용할 Databricks-hosted Claude Model Serving 엔드포인트 이름
DATABRICKS_SERVING_ENDPOINT=databricks-claude-opus-4-8

# (선택) Claude Code의 Haiku 프리셋/경량 백그라운드 모델.
# 직접 Anthropic API 설정 스크립트에서 사용하며, 지정하지 않으면 Haiku 4.5입니다.
# DATABRICKS_FAST_ENDPOINT=databricks-claude-haiku-4-5

# (선택) Claude Code /model의 프리셋 후보
# (공백/콤마 구분). LiteLLM 등록 목록이 아니라 Databricks 네이티브 API에
# 전달할 모델 ID이며, 현재 워크스페이스에서 검증된 모델만 매핑됩니다.
# 기본 후보는 Opus/Sonnet/Haiku입니다.
# Fable 5는 프롬프트와 응답을 30일 보존하고 일부 경우 사람 검토가 가능하므로,
# 정책을 승인한 경우에만 아래처럼 명시적으로 추가하세요.
# DATABRICKS_MODELS="databricks-claude-opus-4-8 databricks-claude-sonnet-5 databricks-claude-haiku-4-5 databricks-claude-fable-5"

# 빠른 로컬 검증용 Databricks Personal Access Token (PAT, legacy)
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
