# Azure Databricks workspace URL (스킴 포함)
# 예: https://adb-1234567890.0.azuredatabricks.net
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net

# Claude Opus 4.8이 배포된 Databricks Model Serving 엔드포인트 이름
DATABRICKS_SERVING_ENDPOINT=databricks-claude-opus-4-8

# (선택) Claude Code의 small/fast 백그라운드 모델.
# 직접 Anthropic API 설정 스크립트에서 사용하며, 지정하지 않으면 Haiku 4.5입니다.
# DATABRICKS_FAST_ENDPOINT=databricks-claude-haiku-4-5

# (선택) Claude Code /model의 Opus/Sonnet/Haiku 프리셋에 매핑할 모델 목록
# (공백/콤마 구분). LiteLLM 등록 목록이 아니라 Databricks 네이티브 API에
# 전달할 모델 ID입니다.
# DATABRICKS_MODELS=databricks-claude-opus-4-8 databricks-claude-sonnet-5 databricks-claude-haiku-4-5

# Databricks Personal Access Token (PAT)
DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
